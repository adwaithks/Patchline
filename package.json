{
	"name": "patchline",
	"version": "0.1.0",
	"description": "Patchline — a desktop Git client for patches, diffs, and commits (Electrobun + React)",
	"scripts": {
		"start": "vite build && electrobun dev",
		"patchline": "bun patchline.ts",
		"patchline:hmr": "bun patchline.ts --hmr",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build": "vite build && electrobun build --env=canary",
		"build:canary": "bun run build"
	},
	"dependencies": {
		"@fontsource/geist-mono": "^5.2.7",
		"@git-diff-view/file": "^0.1.3",
		"@git-diff-view/react": "^0.1.3",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-tooltip": "^1.2.8",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electrobun": "1.16.0",
		"lucide-react": "^0.577.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-icons": "^5.6.0",
		"simple-git": "^3.33.0",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/node": "^25.5.0",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.16",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}
